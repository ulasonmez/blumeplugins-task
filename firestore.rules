rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Helper function to check if user is Ulas
    function isUlas() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName == "Ulas";
    }

    // Helper: Check if user is a member of the plugin
    function isMember(pluginId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/plugins/$(pluginId)/members/$(request.auth.uid));
    }

    // Helper: Check if user is an owner of the plugin (via members role)
    function isPluginOwner(pluginId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/plugins/$(pluginId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/plugins/$(pluginId)/members/$(request.auth.uid)).data.role == "owner";
    }

    // Helper: Check if user is the creator of the plugin document (for initial setup)
    function isCreator(pluginId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/plugins/$(pluginId)).data.createdByUid == request.auth.uid;
    }

    // Users collection: User can read/write only their own doc
    // Allow reading other users' display names for adding members?
    // We need to query users by displayName. So we need read access to users.
    // Let's allow read for authenticated users, write for owner.
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // Plugins collection
    match /plugins/{pluginId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isCreator(pluginId) || 
        isPluginOwner(pluginId) || 
        isUlas() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['startDate', 'endDate']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['endDate']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['startDate'])
      );
      allow delete: if isAuthenticated() && (isCreator(pluginId) || isPluginOwner(pluginId) || isUlas());

      // Members subcollection
      match /members/{memberUid} {
        // Any member can read the member list
        allow read: if isMember(pluginId) || isCreator(pluginId) || isUlas(); 
        // Only owner (or creator during setup) can write/add members
        allow write: if isPluginOwner(pluginId) || isCreator(pluginId) || isUlas();
      }

      // Todos subcollection
      match /todos/{todoId} {
        // Only members can read/write todos
        allow read, write: if isMember(pluginId) || isUlas();
      }

      // Notes subcollection
      match /notes/{uid} {
        // Only members can read notes (or maybe just the owner of the note?)
        // Requirement: "UI da sadece onları render eder" -> implies visibility control
        // Let's say members can read, but only owner of note can write
        allow read: if isMember(pluginId) || isUlas();
        allow write: if (isMember(pluginId) && isOwner(uid)) || isUlas();
      }

      // Messages subcollection (Chat)
      match /messages/{messageId} {
        allow read, write: if isMember(pluginId) || isCreator(pluginId) || isUlas();
      }

      // Files subcollection
      match /files/{fileId} {
        allow read, write: if isMember(pluginId) || isCreator(pluginId) || isUlas();
      }
    }

    // System collection for shared features
    match /system/shared_notepad {
      allow read, write: if isAuthenticated();
    }
  }
}
