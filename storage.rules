rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /attachments/{pluginId}/{uid}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /plugins/{pluginId}/files/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
